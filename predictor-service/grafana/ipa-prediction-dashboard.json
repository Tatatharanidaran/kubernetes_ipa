{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "uid": "ipa-prediction",
  "title": "IPA Prediction",
  "tags": ["ipa", "prediction"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "timezone": "browser",
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Prediction (rps)",
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "axisLabel": "Requests/sec"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "ipa_prediction"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Prediction Range (low / high)",
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "axisLabel": "Requests/sec"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "ipa_prediction_low"
        },
        {
          "refId": "B",
          "expr": "ipa_prediction_high"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Fallback (1 = fallback, 0 = normal)",
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "axisLabel": "Fallback (0/1)"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "ipa_prediction_fallback"
        }
      ],
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Seconds Since Last Accurate Prediction",
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "axisLabel": "Seconds"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - ipa_prediction_last_accuracy_success_timestamp"
        }
      ],
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 }
    }
  ]
}
